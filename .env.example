APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/researchflow.db
AUTO_CREATE_TABLES=true
UPLOAD_DIR=./data/uploads

# Use "fake" for a zero-cost local demo. Use "openai_compatible" for OpenAI,
# DeepSeek, DashScope, or another OpenAI-compatible endpoint.
LLM_MODE=fake
CHAT_API_KEY=
CHAT_BASE_URL=https://api.openai.com/v1
CHAT_MODEL=gpt-4.1-mini
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small

# Use "memory" without Docker and "qdrant" in Docker Compose.
VECTOR_STORE_MODE=memory
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=researchflow_chunks

TAVILY_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_PDF_SIZE_MB=50
MAX_PDF_PAGES=500

