APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite+aiosqlite:///./data/researchflow.db
AUTO_CREATE_TABLES=true
UPLOAD_DIR=./data/uploads

# DeepSeek chat and tool selection through its OpenAI-compatible API.
LLM_MODE=openai_compatible
CHAT_API_KEY=
CHAT_BASE_URL=https://api.deepseek.com
CHAT_MODEL=deepseek-v4-flash
CHAT_THINKING=disabled

# Production paper retrieval through Alibaba Cloud Model Studio (DashScope).
# Never commit a real API key; put it only in the ignored .env file.
EMBEDDING_MODE=dashscope
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1024
EMBEDDING_BATCH_SIZE=10
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=3

RERANK_MODE=dashscope
RERANK_MODEL=qwen3-rerank
RERANK_TIMEOUT_SECONDS=30
RERANK_MAX_RETRIES=3
RETRIEVAL_CANDIDATES=20
RERANK_TOP_N=6

# Local Qdrant persists on disk and does not require Docker.
VECTOR_STORE_MODE=qdrant_local
QDRANT_PATH=./data/qdrant
QDRANT_COLLECTION=researchflow_chunks

# Optional remote Qdrant configuration for later deployment.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

CHUNK_SIZE_TOKENS=800
CHUNK_OVERLAP_TOKENS=120
TABLE_OCR_ENABLED=true
TABLE_OCR_DPI=300
TABLE_OCR_MIN_CONFIDENCE=0.5
RETRIEVAL_SCORE_THRESHOLD=0.0
TAVILY_API_KEY=
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
MAX_PDF_SIZE_MB=50
MAX_PDF_PAGES=500